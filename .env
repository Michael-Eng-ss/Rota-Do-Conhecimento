# ====================================================
# Root .env — lido pelo Docker Compose
# Copie este arquivo e ajuste conforme seu ambiente.
# ====================================================

# ---- PostgreSQL ----
DB_HOST=db
DB_PORT=5432
DB_USER=quizgame
DB_PASSWORD=quizgame123
DB_NAME=quizgame

# ---- Backend ----
PORT=4000
JWT_SECRET=change_me_in_production

# ---- CORS (backend aceita requisições desta origem) ----
CORS_ORIGIN=http://localhost

# ---- Frontend (Vite build args) ----
VITE_API_URL=http://localhost:4000

# Supabase (opcional — deixar vazio para usar somente o backend local)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=
